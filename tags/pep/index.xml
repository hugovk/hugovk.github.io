 srcset="https://hugovk.dev/blog/2025/lazy-imports/inline-imports_hu_e3be42cb0da8959c.webp"
 
 
 sizes="100vw"
 type="image/webp"
 /&gt;
 
 &lt;img
 width="640"
 height="480"
 class="mx-auto my-0 rounded-md"
