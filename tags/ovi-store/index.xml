 sizes="100vw"
 type="image/webp"
 /&gt;
 
 &lt;img
 width="460"
 height="250"
 class="mx-auto my-0 rounded-md"
 alt="Android platform share"
 loading="lazy" decoding="async"
 
 src="https://hugovk.dev/blog/2011/symbian-platform-share/android-chart.png"
 
 /&gt;
